# kivy gui design for app we can switch later to react/flutter or swiftUi but im lazy rn so we can use kivy for now
<PrioritySoundUI>:
    orientation: "vertical"
    padding: 10
    spacing: 10

    BoxLayout:
        size_hint_y: 0.15
        canvas.before:
            Color:
                rgba: root.banner_color
            Rectangle:
                pos: self.pos
                size: self.size
        Label:
            text: root.status_text
            font_size: 20
            bold: True
            halign: "center"
            valign: "middle"

    ScrollView:
        size_hint_y: 0.7
        do_scroll_x: False
        do_scroll_y: True

        Label:
            text: root.transcript_text
            font_size: 16
            text_size: self.width, None
            size_hint_y: None
            height: self.texture_size[1]

    BoxLayout:
        size_hint_y: 0.15
        spacing: 10
        Button:
            text: "↑ Sensitivity"
            on_press: root.increase_sensitivity()
        Button:
            text: "↓ Sensitivity"
            on_press: root.decrease_sensitivity()
        Button:
            text: "False Alert"
            on_press: root.false_alert()
