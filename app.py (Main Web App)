# Import Flask framework components
# flask handles backend routing
# render_template loads HTML files for web ui
# request handles form data from the user
# session stores temporary user login data
from flask import Flask, render_template, request, redirect, session

# import custom modules for user preference storing
# and sound priority logic integration
from user_preferences import UserPreferences
from emergency_detector import EmergencySoundDetector
app = Flask(__name__)
# This allows Flask to store user login data safely
app.secret_key = "prioritysound_secret"
# all the sounds available for users that our software can detect add more sounds in csv 
# sounds that users can prioritize and custom
AVAILABLE_SOUNDS = [
    "baby crying",
    "doorbell ringing",
    "door knocking",
    "dog barking",
    "smoke alarm",
    "fire alarm",
    "police siren",
    "ambulance siren",
    "car horn"
]
# Root route: Login page
# handles both displaying login form (GET)
# and processing login submission (POST)
@app.route("/", methods=["GET", "POST"])
def login():
    if request.method == "POST":
        username = request.form["username"]
        session["username"] = username
        return redirect("/onboarding")
    return render_template("login.html")
# Allows first-time users to select sound priorities
@app.route("/onboarding", methods=["GET", "POST"])
def onboarding():
    username = session.get("username")
    if request.method == "POST":
        preferences = {}
# Loop through all available sounds
# and collect selected priority levels
        for sound in AVAILABLE_SOUNDS:
            priority = request.form.get(sound)
            if priority and priority != "ignore":
                preferences[sound] = priority
        user = UserPreferences(username)
        user.priorities = preferences
        user.save()
        return redirect("/dashboard")
    return render_template("onboarding.html", sounds=AVAILABLE_SOUNDS)
@app.route("/dashboard")
def dashboard():
# retrieve username from past session
    username = session.get("username")
# saves users preferences and loads them for next time
    user = UserPreferences(username)
    return render_template(
        "dashboard.html",
        username=username,
        priorities=user.priorities
    )
if __name__ == "__main__":
    app.run(debug=True)
